{
  "name": "ice-coder",
  "version": "1.0.0",
  "description": "AI coding assistant with tool-use capabilities for PC and mobile",
  "main": "dist/index.js",
  "bin": {
    "iceCoder": "dist/cli/index.js"
  },
  "files": [
    "dist/",
    "data/config.example.json",
    "data/supervisor-config.example.json",
    "data/skills/创建技能.md",
    "data/system-prompt.md",
    "package.json",
    "README.md"
  ],
  "type": "module",
  "scripts": {
    "prebuild": "node scripts/tunnel-pack-entry.cjs",
    "prebuild:server": "node scripts/tunnel-pack-entry.cjs",
    "build": "tsc -p tsconfig.pack.json --listEmittedFiles && vite build && npm pack",
    "build:server": "tsc -p tsconfig.pack.json",
    "build:web": "vite build",
    "start": "cross-env NODE_ENV=production node dist/index.js",
    "dev": "node scripts/dev-entry.mjs",
    "test": "vitest --run",
    "test:coverage": "vitest run --coverage",
    "eval:agent": "tsx scripts/agent-eval.ts",
    "build:desktop:server": "npm run build:server && npm run build:web && node desktop/scripts/copy-server-artifacts.cjs",
    "build:desktop": "npm run build:desktop:server && cd desktop && npm run dist:win && node scripts/copy-release-win.cjs",
    "desktop:build": "cd desktop && npm run build",
    "desktop:dev": "npm run build:desktop:server && cd desktop && npm run dev",
    "desktop:pack": "cd desktop && npm run pack",
    "desktop:dist:win": "cd desktop && npm run dist:win",
    "desktop:dist:mac": "cd desktop && npm run dist:mac",
    "desktop:dist:linux": "cd desktop && npm run dist:linux",
    "desktop:smoke": "cd desktop && npm run smoke:server-bundle",
    "desktop:icons": "node desktop/scripts/generate-icons.mjs"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [],
  "license": "ISC",
  "dependencies": {
    "@types/ws": "^8.18.1",
    "@vscode/ripgrep": "^1.18.0",
    "cheerio": "^1.2.0",
    "domhandler": "^6.0.1",
    "express": "^5.2.1",
    "jszip": "^3.10.1",
    "multer": "^2.1.1",
    "officeparser": "^6.1.0",
    "openai": "^6.34.0",
    "qrcode": "^1.5.4",
    "uuid": "^14.0.0",
    "word-extractor": "^1.0.4",
    "ws": "^8.20.0",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.6.0",
    "@types/qrcode": "^1.5.6",
    "@types/uuid": "^10.0.0",
    "@types/xml2js": "^0.4.14",
    "@vitest/coverage-v8": "^4.1.4",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "jpeg-js": "^0.4.4",
    "playwright": "^1.60.0",
    "png-to-ico": "^2.1.8",
    "sharp": "^0.33.5",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.9",
    "vitest": "^4.1.4"
  }
}
